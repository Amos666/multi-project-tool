{
  "name": "multi-project-tool",
  "displayName": "Multi-Project Tool",
  "description": "A VSCode extension for managing multiple projects with unified Git operations and configuration management",
  "version": "1.0.0",
  "publisher": "default",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:multi-project-tool.main-view"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "node ./node_modules/typescript/bin/tsc -p ./",
    "watch": "node ./node_modules/typescript/bin/tsc -watch -p ./",
    "prepublish": "npm run compile",
    "clean": "rimraf out"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/vscode": "^1.120.0",
    "@vscode/test-electron": "^2.3.8",
    "rimraf": "^5.0.5",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "multi-project-tool",
          "title": "Multi-Project Tool",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "multi-project-tool.openMainView",
        "title": "Multi-Project Tool: Open Main View",
        "category": "Multi-Project Tool"
      },
      {
        "command": "multi-project-tool.refreshProjects",
        "title": "Refresh Projects",
        "category": "Multi-Project Tool"
      }
    ],
    "views": {
      "multi-project-tool": [
        {
          "id": "multi-project-tool.main-view",
          "name": "Multi Project Tools",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "multi-project-tool.openMainView",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Multi-Project Tool",
      "properties": {
        "multi-project-tool.showJsonTab": {
          "type": "boolean",
          "default": true,
          "description": "Show JSON Tab in the sidebar"
        },
        "multi-project-tool.showGitTab": {
          "type": "boolean",
          "default": true,
          "description": "Show Git Tab in the sidebar"
        },
        "multi-project-tool.gitDefaultBranch": {
          "type": "string",
          "default": "main",
          "description": "Default Git branch name"
        },
        "multi-project-tool.projectScanDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum depth to scan for Git projects"
        },
        "multi-project-tool.commonParameters": {
          "type": "object",
          "default": {},
          "description": "Global JSON parameters for command variable substitution"
        },
        "multi-project-tool.defaultShell": {
          "type": "string",
          "enum": ["git-bash", "cmd", "powershell", "wsl"],
          "default": "git-bash",
          "description": "Default shell type for custom commands"
        },
        "multi-project-tool.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh project list on filesystem changes"
        },
        "multi-project-tool.logRetention": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum number of log entries to keep"
        },
        "multi-project-tool.concurrency": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of projects to execute commands concurrently"
        },
        "multi-project-tool.commandTimeout": {
          "type": "number",
          "default": 300,
          "minimum": 10,
          "maximum": 3600,
          "description": "Command execution timeout in seconds"
        },
        "multi-project-tool.customCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "alias": { "type": "string" },
              "content": { "type": "string" }
            },
            "required": ["id", "alias", "content"]
          },
          "default": [],
          "description": "Saved custom commands"
        },
        "multi-project-tool.envVariables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "key": { "type": "string" },
              "value": { "type": "string" }
            },
            "required": ["key", "value"]
          },
          "default": [],
          "description": "Environment variables injected during command execution"
        }
      }
    }
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
  }
}
